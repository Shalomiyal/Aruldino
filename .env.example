# Copy to .env — Supabase: Project Settings → API
# https://supabase.com/dashboard/project/_/settings/api

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Use the "anon" / "public" JWT (starts with eyJ...) — required for sign-in to work reliably.
VITE_SUPABASE_ANON_KEY=

# Optional: newer publishable key (sb_publishable_...) — used only if anon is not set
# VITE_SUPABASE_PUBLISHABLE_KEY=
